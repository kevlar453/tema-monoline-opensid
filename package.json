{
  "name": "theme-ar-modern-1-tailwind",
  "version": "2.0.0",
  "description": "Tema OpenSID ar-modern-1 yang sangat ringan, modern, dan responsive",
  "main": "index.js",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./assets/css/theme.min.css --watch",
    "build:prod": "tailwindcss -i ./src/input.css -o ./assets/css/theme.min.css --minify",
    "dev": "tailwindcss -i ./src/input.css -o ./assets/css/theme.min.css --watch",
    "lint": "eslint assets/js/*.js",
    "lint:fix": "eslint assets/js/*.js --fix"
  },
  "keywords": [
    "ymakarius",
    "theme",
    "tailwind",
    "pure",
    "responsive",
    "modern",
    "css",
    "javascript",
    "no-bootstrap"
  ],
  "author": "ymakarius",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.42.0",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevlar453/tema-monoline-opensid.git"
  },
  "bugs": {
    "url": "https://github.com/kevlar453/tema-monoline-opensid/issues"
  },
  "homepage": "https://github.com/kevlar453/tema-monoline-opensid#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
